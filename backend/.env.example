FRONTEND_ORIGINS=https://truthshield-ai-frontend.pages.dev

# Enhanced verification is free-only and falls back safely when optional tools are absent.
ENABLE_ENHANCED_ANALYSIS=true

# Optional free Brave Search key. Leave blank for local-only reports.
BRAVE_SEARCH_API_KEY=
WEB_RESEARCH_PER_SCAN_LIMIT=2
WEB_RESEARCH_MONTHLY_LIMIT=150

# Optional uploaded-image web matching. This can return full/partial visual
# matches and pages containing the uploaded image.
GOOGLE_VISION_API_KEY=
GOOGLE_VISION_MAX_RESULTS=10

# The packaged TruthShield model is selected automatically. Add extra model IDs
# only for experiments; a packaged local model remains the primary detector.
ENABLE_LOCAL_AI_MODELS=true
AI_IMAGE_DETECTOR_MODELS=

# Deep video mode. Stride 1 and max 0 analyze every decoded frame. Tiled
# analysis is substantially slower but covers the full frame with overlaps.
AI_VIDEO_FRAME_DETECTOR_MODELS=
AI_VIDEO_TEMPORAL_MODEL_PATH=
VIDEO_ANALYSIS_MODE=exhaustive
VIDEO_FRAME_STRIDE=1
VIDEO_MAX_FRAMES=0
VIDEO_TILE_ANALYSIS=true
VIDEO_TILE_SIZE=448
VIDEO_TILE_OVERLAP=0.15

# Optional local Ollama/OpenAI-compatible endpoint for rewriting feedback.
# Deterministic feedback is used when this is blank or unreachable.
LOCAL_REASONING_BASE_URL=
